app.post('/v1/chat/completions', asyncRoute(async (req, res) => {
  const body = req.body || {};
  const msgs = Array.isArray(body.messages) ? body.messages.slice() : [];
  const totalChars = msgs.reduce((s,m)=>s+(typeof m.content==='string'?m.content.length:JSON.stringify(m.content||'').length),0);
  const lastUser = (msgs.filter(m=>m.role==='user').slice(-1)[0] || {}).content;
  log('info','ai_proxy_incoming',{model: body.model, stream: body.stream===true, msg_count: msgs.length, total_chars: totalChars, last_user_head: typeof lastUser==='string' ? lastUser.slice(0,400):null});

  if (!msgs.some(m => m && m.role === 'system')) {
    msgs.unshift({ role: 'system', content: '你是专业的企业工作助手与数据分析师。请直接以中文输出最终答案，结果使用 Markdown 格式。不要返回空内容；即使信息不足，也要给出一份合理的报告框架和各部分占位内容。' });
  }
  const streaming = body.stream === true;
  const payload = Object.assign({}, body, { messages: msgs });
  if (!payload.model) payload.model = DEFAULT_MODEL;

  async function callOnce(p) {
    return new Promise((resolve, reject) => {
      const b = JSON.stringify(p);
      const opts = {
        hostname: AI_HOSTNAME, port: 443, path: AI_PATH, method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + AI_KEY, 'Content-Length': Buffer.byteLength(b) },
        timeout: AI_TIMEOUT,
      };
      const r = https.request(opts, (pr) => {
        const chunks = [];
        pr.on('data', (c) => chunks.push(c));
        pr.on('end', () => resolve({ status: pr.statusCode, headers: pr.headers, bodyText: Buffer.concat(chunks).toString('utf-8') }));
      });
      r.on('error', reject);
      r.on('timeout', () => r.destroy(new Error('AI upstream timeout')));
      r.write(b); r.end();
    });
  }

  if (streaming) {
    const b = JSON.stringify(payload);
    const opts = {
      hostname: AI_HOSTNAME, port: 443, path: AI_PATH, method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + AI_KEY, 'Content-Length': Buffer.byteLength(b) },
      timeout: AI_TIMEOUT,
    };
    const proxyReq = https.request(opts, (pr) => { res.writeHead(pr.statusCode, pr.headers); pr.pipe(res); });
    proxyReq.on('error', (e) => { log('error','ai_proxy_error',{error:e.message}); if (!res.headersSent) res.status(502).json({error:'AI upstream error: '+e.message}); });
    proxyReq.on('timeout', () => proxyReq.destroy(new Error('AI upstream timeout')));
    proxyReq.write(b); proxyReq.end();
    return;
  }

  let resp;
  try { resp = await callOnce(payload); }
  catch (e) { log('error','ai_proxy_error',{error:e.message}); return res.status(502).json({error:'AI upstream error: '+e.message}); }

  let parsed = null;
  try { parsed = JSON.parse(resp.bodyText); } catch (e) {}
  const getContent = (p) => { try { return p.choices[0].message.content || null; } catch { return null; } };
  const getReason  = (p) => { try { return p.choices[0].message.reasoning_content || null; } catch { return null; } };

  if (parsed && getContent(parsed) == null) {
    log('warn','ai_content_null_retry',{tokens: parsed.usage});
    const retry = Object.assign({}, payload);
    retry.messages = msgs.slice();
    retry.messages.push({ role: 'user', content: '请以 Markdown 正文直接输出最终报告全文。不要返回空内容，不要只输出思考过程。' });
    try {
      const resp2 = await callOnce(retry);
      const parsed2 = JSON.parse(resp2.bodyText);
      if (getContent(parsed2)) { parsed = parsed2; }
      else if (getReason(parsed2)) { parsed2.choices[0].message.content = getReason(parsed2); parsed = parsed2; }
    } catch (e) { log('error','ai_retry_failed',{error: e.message}); }
  }

  if (parsed && getContent(parsed) == null) {
    const reason = getReason(parsed);
    parsed.choices[0].message.content = reason ||
      '# 报告生成暂时不可用\n\n上游模型本次未返回内容（可能是推理模型特性）。请再次点击“一键生成”或稍后重试。\n\n如多次出现该问题，请切换到非推理模型（如 claude-sonnet-4-6 或 gpt-5.2）。';
  }

  const outBody = JSON.stringify(parsed || { error: 'upstream invalid', raw: resp.bodyText.slice(0,500) });
  res.status(resp.status || 200);
  res.setHeader('Content-Type', 'application/json; charset=utf-8');
  res.end(outBody);
}));

/* CODEX_CALLAI_RETRY */
async function callAi(messages, model) {
  const body = JSON.stringify({ model: model || DEFAULT_MODEL, messages });
  const opts = {
    hostname: AI_HOSTNAME, port: 443, path: '/v1/chat/completions', method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + AI_KEY, 'Content-Length': Buffer.byteLength(body) },
    timeout: AI_TIMEOUT,
  };
  return new Promise((resolve, reject) => {
    const r = https.request(opts, (pr) => {
      const chunks = [];
      pr.on('data', (c) => chunks.push(c));
      pr.on('end', () => {
        const txt = Buffer.concat(chunks).toString('utf-8');
        if (pr.statusCode >= 400) return reject(new Error('AI HTTP ' + pr.statusCode + ': ' + txt.slice(0, 500)));
        try { resolve(JSON.parse(txt)); } catch (e) { reject(new Error('AI parse: ' + e.message)); }
      });
    });
    r.on('error', reject);
    r.on('timeout', () => r.destroy(new Error('AI upstream timeout')));
    r.write(body); r.end();
  });
}

async function callAiSafe(rawMessages, model) {
  const messages = (rawMessages || []).slice();
  // ensure at least one system message to steer gpt-5.4 away from reasoning-only mode
  if (!messages.some(m => m && m.role === 'system')) {
    messages.unshift({ role: 'system', content: '请直接以中文回答，给出具体、可操作的最终回复。不要返回空内容，不要只输出思考过程。' });
  }
  let data = await callAi(messages, model);
  let content = (data && data.choices && data.choices[0] && data.choices[0].message && data.choices[0].message.content) || null;
  if (!content) {
    log('warn', 'callai_null_retry', { usage: data && data.usage });
    const retry = messages.slice();
    retry.push({ role: 'user', content: '请直接给出最终回复（Markdown），不要返回空内容。' });
    data = await callAi(retry, model);
    content = (data && data.choices && data.choices[0] && data.choices[0].message && data.choices[0].message.content) || null;
    if (!content) {
      const rc = data && data.choices && data.choices[0] && data.choices[0].message && data.choices[0].message.reasoning_content;
      content = rc || '当前上游模型本次未返回内容，请稍后重试。';
      data.choices[0].message.content = content;
    }
  }
  return data;
}

