function asyncRoute(fn) {
  return (req, res, next) => {
    Promise.resolve(fn(req, res, next)).catch((err) => {
      log('error', 'handler_error', { method: req.method, url: req.originalUrl, error: err && err.message, stack: err && err.stack });
