function validUsername(u) { return typeof u === 'string' && /^[a-zA-Z0-9_.\-]{3,32}$/.test(u); }
function validPassword(p) { return typeof p === 'string' && p.length >= 6 && p.length <= 200; }
function touchLogin(uid) { pool.query('UPDATE auth_users SET last_login_at=NOW(), login_count=login_count+1 WHERE id=?', [uid]).catch(()=>{}); }
function issueCookie(res, user) {
  const token = signSession({ u: user.username, uid: user.id, role: user.role, iat: Date.now(), exp: Date.now() + AUTH_MAX_AGE });
  res.setHeader('Set-Cookie', AUTH_COOKIE + '=' + encodeURIComponent(token) + '; Max-Age=' + Math.floor(AUTH_MAX_AGE/1000) + '; Path=/; SameSite=Lax; Secure');
  return token;
}

const AUTH_PUBLIC_PATHS = [ /^\/healthz$/, /^\/auth\//, /^\/api\/market\//, /^\/api\/scenarios/, /^\/api\/token\//, /^\/api\/stats\//, /^\/api\/activities/, /^\/api\/approvals/, /^\/api\/tasks/, /^\/api\/agents/, /^\/agents/, /^\/api\/workflows/,  /^\/knowledge/, /^\/api\/knowledge/ ];


function isPublic(path) {
  return AUTH_PUBLIC_PATHS.some(pattern => pattern.test(path));
}
app.post('/auth/register', asyncRoute(async (req, res) => {
  if (!ALLOW_REGISTRATION) return res.status(403).json({ error: '管理员已关闭自助注册' });
  const ip = (req.headers['x-forwarded-for'] || req.ip || '').toString().split(',')[0].trim() || 'unknown';
  if (rateLimit('reg:' + ip, 5, 10 * 60 * 1000)) return res.status(429).json({ error: '注册过于频繁，请稍后再试' });
  const { username, password } = req.body || {};
  if (!validUsername(username)) return res.status(400).json({ error: '用户名格式不合法（字母/数字/. _ -，3-32 位）' });
  if (!validPassword(password)) return res.status(400).json({ error: '密码至少 6 位' });
  const [dup] = await pool.query('SELECT id FROM auth_users WHERE username = ?', [username]);
  if (dup.length) return res.status(409).json({ error: '用户名已存在' });
  const h = hashPassword(password);
  const [r] = await pool.query("INSERT INTO auth_users (username, password_hash, role, status) VALUES (?, ?, 'user', 'active')", [username, h]);
  const userId = r.insertId;
  
  // 初始化用户余额（注册赠送10元）
  await pool.query('INSERT INTO user_balance (user_id, balance, total_recharged, total_consumed) VALUES (?, 10.00, 0, 0)', [userId]);
  
  log('info', 'auth_register_ok', { username, id: userId, ip });
  issueCookie(res, { id: userId, username, role: 'user' });
  res.json({ success: true, user: { id: userId, username, role: 'user' } });
}));

app.post('/auth/login', asyncRoute(async (req, res) => {
  const ip = (req.headers['x-forwarded-for'] || req.ip || '').toString().split(',')[0].trim() || 'unknown';
  if (rateLimit('login:' + ip, 10, 5 * 60 * 1000)) return res.status(429).json({ error: '登录过于频繁，请稍后再试' });
  const body = req.body || {};
  const username = body.username || body.user;
  const password = body.password;
  if (!username || !password) return res.status(400).json({ error: '请输入用户名和密码' });
  const [rows] = await pool.query("SELECT id, username, password_hash, role, status FROM auth_users WHERE username = ? LIMIT 1", [username]);
  const user = rows[0];
  if (!user) { log('warn','auth_login_unknown',{username, ip}); return res.status(401).json({ error: '用户名或密码错误' }); }
  if (user.status !== 'active') return res.status(403).json({ error: '账户已禁用' });
  if (!verifyPassword(password, user.password_hash)) { log('warn','auth_login_bad',{username, ip}); return res.status(401).json({ error: '用户名或密码错误' }); }
  touchLogin(user.id);
  const token = issueCookie(res, user);
  log('info', 'auth_login_ok', { username, id: user.id, ip });
  res.json({ success: true, token, user: { id: user.id, username: user.username, role: user.role } });
}));

