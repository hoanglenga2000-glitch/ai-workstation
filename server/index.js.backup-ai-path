app.post('/api/market/agents/:id/use', asyncRoute(async (req, res) => {
  const agentId = req.params.id;
  const { input_text } = req.body || {};
  const userId = req.user ? req.user.id : 1; // 从认证中间件获取用户ID
  
  // 获取智能体信息
  const [agentRows] = await pool.query('SELECT * FROM agent_market WHERE id=?', [agentId]);
  if (!agentRows.length) return res.status(404).json({ error: 'Agent not found' });
  const agent = agentRows[0];
  
  // 检查用户余额（如果是付费智能体）
  if (agent.price_type !== 'free') {
    const [balanceRows] = await pool.query('SELECT * FROM user_balance WHERE user_id=?', [userId]);
    if (!balanceRows.length || balanceRows[0].balance <= 0) {
      return res.status(402).json({ error: '余额不足，请充值' });
    }
  }
  
  // 替换提示词模板中的占位符
  const prompt = agent.prompt_template.replace('{user_input}', input_text || '');
  
  // 调用 AI 模型
  const startTime = Date.now();
  try {
    const aiResponse = await callAI(prompt, agent.model);
    const duration = Date.now() - startTime;
    
    // 计算成本
    const [modelRows] = await pool.query('SELECT * FROM model_market WHERE model_id=?', [agent.model]);
    let cost = 0;
    if (modelRows.length && aiResponse.usage) {
      const model = modelRows[0];
      cost = (aiResponse.usage.prompt_tokens * model.price_input / 1000) + 
             (aiResponse.usage.completion_tokens * model.price_output / 1000);
    }
    
    // 记录使用日志
    await pool.query(
      'INSERT INTO agent_usage_log (user_id, agent_id, input_text, output_text, tokens_used, cost, duration_ms, status) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
      [userId, agentId, input_text, aiResponse.content, aiResponse.usage?.total_tokens || 0, cost, duration, 'success']
    );
    
    // 记录 Token 使用
    if (aiResponse.usage) {
      await pool.query(
        'INSERT INTO token_usage (user_id, agent_id, model_id, prompt_tokens, completion_tokens, total_tokens, cost) VALUES (?, ?, ?, ?, ?, ?, ?)',
        [userId, agentId, agent.model, aiResponse.usage.prompt_tokens, aiResponse.usage.completion_tokens, aiResponse.usage.total_tokens, cost]
      );
    }
    
    // 更新智能体使用次数
    await pool.query('UPDATE agent_market SET usage_count=usage_count+1 WHERE id=?', [agentId]);
    
    // 扣费（如果是付费智能体）
    if (agent.price_type !== 'free' && cost > 0) {
      await pool.query('UPDATE user_balance SET balance=balance-?, total_consumed=total_consumed+? WHERE user_id=?', [cost, cost, userId]);
    }
    
    res.json({
      success: true,
      output: aiResponse.content,
      usage: aiResponse.usage,
      cost: cost,
      duration_ms: duration
    });
  } catch (error) {
    const duration = Date.now() - startTime;
    await pool.query(
      'INSERT INTO agent_usage_log (user_id, agent_id, input_text, tokens_used, cost, duration_ms, status, error_msg) VALUES (?, ?, ?, 0, 0, ?, ?, ?)',
      [userId, agentId, input_text, duration, 'error', error.message]
    );
    throw error;
  }
}));

// AI 调用辅助函数
async function callAI(prompt, model) {
  return new Promise((resolve, reject) => {
    const payload = JSON.stringify({
      model: model || DEFAULT_MODEL,
      messages: [{ role: 'user', content: prompt }],
      stream: false
    });
    
    const options = {
      hostname: AI_HOSTNAME,
      path: '/v1/chat/completions',
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${AI_KEY}`,
        'Content-Length': Buffer.byteLength(payload)
      },
      timeout: AI_TIMEOUT
    };
    
    const req = https.request(options, (res) => {
      let data = '';
      res.on('data', (chunk) => { data += chunk; });
      res.on('end', () => {
        try {
          const json = JSON.parse(data);
          if (json.error) return reject(new Error(json.error.message || 'AI API error'));
          resolve({
            content: json.choices?.[0]?.message?.content || '',
            usage: json.usage
          });
        } catch (e) {
          reject(new Error('Failed to parse AI response'));
        }
      });
    });
    
    req.on('error', reject);
    req.on('timeout', () => {
      req.destroy();
      reject(new Error('AI request timeout'));
    });
    req.write(payload);
    req.end();
  });
}

