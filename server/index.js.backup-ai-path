  // 如果是浏览器请求 /workflows/* 子路径，跳过认证（让前端路由处理）
  if (req.path.startsWith('/workflows/') && req.path !== '/workflows/') {
    const acceptHeader = req.get('Accept') || '';
    const htmlIndex = acceptHeader.indexOf('text/html');
    const jsonIndex = acceptHeader.indexOf('application/json');
    if (htmlIndex >= 0 && (jsonIndex < 0 || htmlIndex < jsonIndex)) {
      return next();
    }
  }

  const session = verifySession(req.cookies && req.cookies[AUTH_COOKIE]);
  if (!session) return res.status(401).json({ error: 'authentication required' });

  req.user = session;
  next();
});



