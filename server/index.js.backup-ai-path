// Token API helper: extract user from cookie
function tokenAuth(req) {
  const session = verifySession(req.cookies && req.cookies[AUTH_COOKIE]);
  if (session) {
    req.user = { id: session.uid, username: session.u, role: session.role };
  }
  return !!session;
}

