# Environment for ai.zhjjq.tech API server
PORT=3100
HOST=127.0.0.1

# Database (MySQL)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=ai-zhjjq
DB_CONNECTION_LIMIT=10

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# AI provider (阿里百炼)
LTCRAFT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LTCRAFT_API_KEY=your_api_key_here
DEFAULT_MODEL=deepseek-v4-flash
AI_CALL_TIMEOUT_MS=120000

# Upload
UPLOAD_MAX_SIZE_MB=20

# Auth
AUTH_PASSWORD=admin123
AUTH_SECRET=your_random_secret_at_least_32_chars_here
ALLOW_REGISTRATION=true

# Feature Flags
FEATURE_REDIS_RL=true
FEATURE_JWT_AUTH=true
